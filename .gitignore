# Ignore binary files
*.exe
*.dll
*.so
*.dylib

# Ignore Mac environment files
.DS_Store
.AppleDouble
.LSOverride

# Ignore garbage files generated by programming languages
*.class
*.pyc
*.o
*.obj
*.swp
*.swo
*.sln.cache
*.bak
*.tmp
*.tmp.*
*.~lock.*

# Ignore files generated by IDEs
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Ignore log files
*.log
log.txt

# Ignore cache files
*.cache
__pycache__/
